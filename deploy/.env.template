# =============================================================================
# SCBE-AETHERMOORE API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
#
# Usage: cp deploy/.env.template .env && nano .env
# =============================================================================

# --- Core API ---
PORT=8080
SCBE_API_KEY=your-api-key-here
SCBE_LOG_LEVEL=INFO

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- AI Providers ---
# Vercel AI Gateway
VERCEL_AI_API_KEY=your-vercel-ai-key

# HuggingFace Inference
HF_TOKEN=hf_your_huggingface_token

# Browserbase (cloud browser)
BROWSERBASE_API_KEY=your-browserbase-key
BROWSERBASE_PROJECT_ID=your-project-id

# --- Optional Integrations ---
# Notion (for content sync)
NOTION_API_KEY=your-notion-key

# Airtable (via Zapier bridge initially)
# AIRTABLE_API_KEY=your-airtable-key

# Google Drive (for training data sync)
# GOOGLE_DRIVE_ACCESS_TOKEN=your-google-token

# --- Database ---
SCBE_METERING_DB_PATH=/app/data/scbe_metering.db
