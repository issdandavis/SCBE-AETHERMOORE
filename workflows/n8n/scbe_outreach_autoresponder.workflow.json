              {
                "role": "user",
                "content": "Draft a reply to this email. Sender: {{ $json.from.value[0].address }}. Subject: {{ $json.subject }}. Their message: {{ $json.text }}"
              }
            ],
            "max_tokens": 600,
            "temperature": 0.4
          }
        }
      },
      "name": "Draft Reply via HF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [910, 300]
    },
    {
      "parameters": {
        "sendTo": "aethermoregames@pm.me",
        "subject": "DRAFT REPLY: {{ $node['Gmail Trigger'].json.subject }}",
        "message": "FROM: {{ $node['Gmail Trigger'].json.from.value[0].address }}\nSUBJECT: {{ $node['Gmail Trigger'].json.subject }}\n\n--- THEIR MESSAGE ---\n{{ $node['Gmail Trigger'].json.text }}\n\n--- DRAFT REPLY ---\n{{ $json.choices[0].message.content }}\n\n--- REVIEW AND SEND FROM GMAIL ---"
      },
      "name": "Send Draft to Review",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1130, 300]
    }
  ],
  "connections": {
    "Gmail Trigger": { "main": [[{ "node": "Filter Outreach Contacts", "type": "main", "index": 0 }]] },
    "Filter Outreach Contacts": { "main": [[{ "node": "Governance Scan", "type": "main", "index": 0 }]] },
    "Governance Scan": { "main": [[{ "node": "Draft Reply via HF", "type": "main", "index": 0 }]] },
    "Draft Reply via HF": { "main": [[{ "node": "Send Draft to Review", "type": "main", "index": 0 }]] }
  }
}
