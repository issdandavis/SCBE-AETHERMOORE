+<script>
+function trimSlash(value) {
+  return String(value || "").replace(/\/+$/, "");
+}
+
+function resolveProxyEndpoint() {
+  const params = new URLSearchParams(window.location.search);
+  const explicitProxy = params.get("proxy");
+  if (explicitProxy) return explicitProxy;
+
+  const explicitBase = params.get("apiBase");
+  if (explicitBase) return `${trimSlash(explicitBase)}/v1/research/mobile-chat`;
+
+  const host = window.location.hostname;
+  const protocol = window.location.protocol;
+  const isCapacitor = Boolean(window.Capacitor) || protocol === "capacitor:" || protocol === "file:";
+  const isEmulator = host === "10.0.2.2";
+  const isLocalBrowser = host === "localhost" || host === "127.0.0.1";
+
+  if (isCapacitor || isEmulator) return "http://10.0.2.2:8000/v1/research/mobile-chat";
+  if (isLocalBrowser) return "http://localhost:8000/v1/research/mobile-chat";
+  return `${window.location.origin}/v1/research/mobile-chat`;
+}
+
+function compareModelsFromQuery() {
+  const params = new URLSearchParams(window.location.search);
+  const value = params.get("compare");
+  if (!value) return [];
+  return value.split(",").map((item) => item.trim()).filter(Boolean);
+}
+
+function allowSecretFields() {
+  const params = new URLSearchParams(window.location.search);
+  return params.get("secrets") === "1";
+}
+
+function loadWidgetScript() {
+  const candidates = [
+    "./static/polly-hf-chat.js",
+    "../kindle-app/www/static/polly-hf-chat.js",
+  ];
+
+  return new Promise((resolve, reject) => {
+    function next(index) {
+      if (window.PollyHFChat) {
+        resolve();
+        return;
+      }
+      const src = candidates[index];
+      if (!src) {
+        reject(new Error("Polly widget script is unavailable."));
+        return;
+      }
+      const script = document.createElement("script");
+      script.src = src;
+      script.onload = () => resolve();
+      script.onerror = () => {
+        script.remove();
