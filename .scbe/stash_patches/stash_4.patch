-  const preferred = ['google_ai', 'claude', 'xai', 'github_models', 'huggingface', 'ollama', 'groq', 'cerebras', 'openrouter'];
-  const inPref = preferred.filter(id => avail.includes(id));
-  const rest = avail.filter(id => !inPref.includes(id));
-  return [...inPref, ...rest];
