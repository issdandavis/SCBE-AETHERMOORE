        { "id": "overseer",   "name": "Overseer",  "appId": "overseer",   "icon": "Shield",       "bgColor": "bg-gradient-to-br from-cyan-600 to-fuchsia-600" },
        { "id": "fleet",      "name": "Fleet",     "appId": "fleet",      "icon": "ShieldCheck",  "bgColor": "bg-indigo-600" },
