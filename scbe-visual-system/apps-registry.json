        { "id": "automator",  "name": "Automator",   "appId": "automator",  "icon": "Share2",       "bgColor": "bg-violet-600" },
        { "id": "mail",      "name": "Mail",       "appId": "mail",      "icon": "Mail",         "bgColor": "bg-blue-600" },
