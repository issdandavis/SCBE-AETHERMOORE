# ──────────────────────────────────────────────────────────────
# SCBE Repo Manager — GitHub App Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values from your
# GitHub App settings at https://github.com/settings/apps
# ──────────────────────────────────────────────────────────────

# Required — from "General" tab of your GitHub App
APP_ID=
PRIVATE_KEY_PATH=./private-key.pem
WEBHOOK_SECRET=

# Required for OAuth features (optional if not using user auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Development only — smee.io proxy URL for local webhook forwarding
# Create one at https://smee.io/new
WEBHOOK_PROXY_URL=

# Optional — override log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Optional — override the webhook path (default: /)
WEBHOOK_PATH=/

# Optional — set to "true" to run the daily scheduled tasks
ENABLE_SCHEDULED_TASKS=true

# Optional — stale threshold in days (default: 30)
STALE_DAYS=30
