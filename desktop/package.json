{
  "name": "aetherbrowser",
  "version": "0.1.5",
  "description": "AetherBrowser — AI-governed desktop browser with multi-agent sidepanel",
  "author": "Issac Daniel Davis <issdandavis@gmail.com>",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite build --watch & electron .",
    "dev:electron": "electron .",
    "dev:vite": "vite build --watch",
    "build": "vite build",
    "package": "electron-builder --win",
    "package:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.aethermoorgames.aetherbrowser",
    "productName": "AetherBrowser",
    "copyright": "Copyright © 2026 Issac Daniel Davis",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "AetherBrowser-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AetherBrowser",
      "uninstallDisplayName": "AetherBrowser"
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.0",
    "playwright-core": "^1.61.1",
    "vite": "^8.0.16"
  }
}
