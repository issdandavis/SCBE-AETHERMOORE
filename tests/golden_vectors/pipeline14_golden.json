      "tolerance": 1e-12
    },
    {
      "id": "shell-radius-k2",
      "layer": "L12",
      "function": "phi_shell_radius",
      "description": "k=2: r = phi^2 / (1+phi^2).",
      "inputs": {"k": 2},
      "expected": 0.7236067977499789,
      "tolerance": 1e-12
    },
    {
      "id": "shell-radius-k3",
      "layer": "L12",
      "function": "phi_shell_radius",
      "description": "k=3: r = phi^3 / (1+phi^3).",
      "inputs": {"k": 3},
      "expected": 0.8090169943749475,
      "tolerance": 1e-12
    },
    {
      "id": "shell-radius-k4",
      "layer": "L12",
      "function": "phi_shell_radius",
      "description": "k=4: r = phi^4 / (1+phi^4).",
      "inputs": {"k": 4},
      "expected": 0.872677996249965,
      "tolerance": 1e-12
    },
    {
      "id": "shell-radius-k5",
      "layer": "L12",
      "function": "phi_shell_radius",
      "description": "k=5: r = phi^5 / (1+phi^5). Approaches 1 (boundary).",
      "inputs": {"k": 5},
      "expected": 0.9172881767044977,
      "tolerance": 1e-12
    },
    {
      "id": "harmonic-cost-at-shell-k0",
      "layer": "L12",
      "function": "harmonic_cost_at_shell",
      "description": "Cost at shell 0 with R=4: H(r(0), 4) = 4^(0.5^2) = 4^0.25 = sqrt(2).",
      "inputs": {"k": 0, "R": 4.0},
      "expected": 1.4142135623730951,
      "tolerance": 1e-12
    },
    {
      "id": "harmonic-cost-at-shell-k3",
      "layer": "L12",
      "function": "harmonic_cost_at_shell",
      "description": "Cost at shell 3 with R=4: 4^(r(3)^2) = 4^(0.80902^2).",
      "inputs": {"k": 3, "R": 4.0},
      "expected": 2.4777265820315924,
      "tolerance": 1e-10
    },
    {
      "id": "harmonic-cost-at-shell-k5",
      "layer": "L12",
      "function": "harmonic_cost_at_shell",
      "description": "Cost at shell 5 with R=4: 4^(r(5)^2). Near boundary = high cost.",
      "inputs": {"k": 5, "R": 4.0},
      "expected": 3.2105827830318856,
      "tolerance": 1e-10
    },
    {
      "id": "fibonacci-consensus-empty",
      "layer": "consensus",
      "function": "fibonacci_ternary_consensus",
      "description": "Empty history: index stays at 0, FIB[0]=1.",
      "inputs": {"history": []},
      "expected": 1,
      "tolerance": 0
    },
    {
      "id": "fibonacci-consensus-1-activate",
      "layer": "consensus",
      "function": "fibonacci_ternary_consensus",
