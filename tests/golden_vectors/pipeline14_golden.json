{
  "version": "1.0.0",
  "description": "Golden test vectors for the 14-layer pipeline. All expected values are derived from closed-form math, not copied from implementation output. Both TypeScript (canonical) and Python (reference) must match these vectors.",
  "constants": {
    "PHI": 1.618033988749895,
    "PHI_NOTE": "(1 + sqrt(5)) / 2"
  },
  "vectors": [
    {
      "id": "L5-hyperbolic-distance-origin-to-axis",
      "layer": "L5",
      "function": "hyperbolic_distance_poincare",
      "description": "dH(u,v) = acosh(1 + 2*||u-v||^2 / ((1-||u||^2)(1-||v||^2))). Origin to (0.5, 0).",
      "inputs": {"u": [0.0, 0.0], "v": [0.5, 0.0]},
      "expected": 1.0986122886681096,
      "tolerance": 1e-12
    },
    {
      "id": "L5-hyperbolic-distance-2d-diagonal",
      "layer": "L5",
      "function": "hyperbolic_distance_poincare",
      "description": "2D points with both components nonzero.",
      "inputs": {"u": [0.1, 0.2], "v": [0.3, 0.4]},
      "expected": 0.6582194273693331,
      "tolerance": 1e-12
    },
    {
      "id": "L5-hyperbolic-distance-perpendicular",
      "layer": "L5",
      "function": "hyperbolic_distance_poincare",
      "description": "Two points at equal Euclidean distance from origin but on perpendicular axes.",
      "inputs": {"u": [0.3, 0.0], "v": [0.0, 0.3]},
      "expected": 0.901599472981844,
      "tolerance": 1e-12
    },
    {
      "id": "L5-hyperbolic-distance-near-boundary",
      "layer": "L5",
      "function": "hyperbolic_distance_poincare",
      "description": "Points near the Poincare ball boundary where distance grows rapidly.",
      "inputs": {"u": [0.9, 0.0], "v": [0.0, 0.9]},
      "expected": 5.201232927686145,
      "tolerance": 1e-10
    },
    {
      "id": "L5-hyperbolic-distance-symmetric-opposites",
      "layer": "L5",
      "function": "hyperbolic_distance_poincare",
      "description": "Symmetric opposite points in 2D Poincare ball.",
      "inputs": {"u": [0.5, 0.5], "v": [-0.5, -0.5]},
      "expected": 3.5254943480781717,
      "tolerance": 1e-12
    },
    {
      "id": "L12-harmonic-wall-d0-R4",
      "layer": "L12",
      "function": "harmonic_wall",
      "description": "H(d, R) = R^(d^2). At d=0 cost is always 1 (safe center).",
      "inputs": {"d": 0.0, "R": 4.0},
      "expected": 1.0,
      "tolerance": 1e-15
    },
    {
      "id": "L12-harmonic-wall-d0.5-R4",
      "layer": "L12",
      "function": "harmonic_wall",
      "description": "H(0.5, 4) = 4^0.25 = sqrt(2).",
      "inputs": {"d": 0.5, "R": 4.0},
      "expected": 1.4142135623730951,
      "tolerance": 1e-12
    },
    {
      "id": "L12-harmonic-wall-d1-R4",
      "layer": "L12",
      "function": "harmonic_wall",
      "description": "H(1.0, 4) = 4^1 = 4. At boundary, full base cost.",
      "inputs": {"d": 1.0, "R": 4.0},
      "expected": 4.0,
      "tolerance": 1e-15
    },
    {
      "id": "L12-harmonic-wall-d0.3-R2",
      "layer": "L12",
      "function": "harmonic_wall",
      "description": "H(0.3, 2) = 2^0.09.",
      "inputs": {"d": 0.3, "R": 2.0},
      "expected": 1.0643701824533598,
      "tolerance": 1e-12
    },
    {
      "id": "L12-harmonic-wall-d0.9-R10",
      "layer": "L12",
      "function": "harmonic_wall",
      "description": "H(0.9, 10) = 10^0.81. Near boundary with large R.",
      "inputs": {"d": 0.9, "R": 10.0},
      "expected": 6.456542290346556,
      "tolerance": 1e-10
    },
    {
      "id": "tongue-weights-phi-k",
      "layer": "langues",
      "function": "tongue_weights",
      "description": "Sacred Tongue weights: PHI^k for k=0..5 (KO, AV, RU, CA, UM, DR).",
      "inputs": {"k_values": [0, 1, 2, 3, 4, 5]},
      "expected": [1.0, 1.618033988749895, 2.618033988749895, 4.23606797749979, 6.854101966249686, 11.090169943749476],
      "tolerance": 1e-12
    },
    {
      "id": "shell-radius-k0",
