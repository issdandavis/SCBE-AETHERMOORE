      "inputs": {"history": [1]},
      "expected": 1,
      "tolerance": 0
    },
    {
      "id": "fibonacci-consensus-3-activate",
      "layer": "consensus",
      "function": "fibonacci_ternary_consensus",
      "description": "Three +1s: climb to index 3, FIB[3]=3.",
