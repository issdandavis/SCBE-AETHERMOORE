      "expected": 3,
      "tolerance": 0
    },
    {
      "id": "fibonacci-consensus-5-activate",
      "layer": "consensus",
      "function": "fibonacci_ternary_consensus",
      "description": "Five +1s: climb to index 5, FIB[5]=8.",
      "inputs": {"history": [1, 1, 1, 1, 1]},
      "expected": 8,
      "tolerance": 0
    },
    {
      "id": "fibonacci-consensus-10-activate",
      "layer": "consensus",
      "function": "fibonacci_ternary_consensus",
      "description": "Ten +1s: climb to index 10, FIB[10]=89.",
