{
  "version": "1.0.0",
  "metric": "exponential_map",
  "formula": "exp_p(v) = p (+) (tanh(lambda_p * ||v|| / 2) * v / ||v||), with lambda_p = 2 / (1 - ||p||^2)",
  "tolerance": "abs <= 1e-12",
  "cases": [
    {
      "id": "simple_2d",
      "p": [0.1, 0.2],
      "v": [0.3, 0.4],
      "expected": [0.3428011280886502, 0.5357842000335175]
    },
    {
      "id": "origin_to_axis",
      "p": [0.0, 0.0],
      "v": [0.5, 0.0],
      "expected": [0.46211715726000974, 0.0]
    },
    {
      "id": "symmetric_opposites",
      "p": [0.5, 0.5],
      "v": [-0.5, -0.5],
      "expected": [-0.3447491957971917, -0.3447491957971917]
    },
    {
      "id": "simple_3d",
      "p": [0.1, 0.1, 0.1],
      "v": [0.2, 0.2, 0.2],
      "expected": [0.2811576101888096, 0.2811576101888096, 0.2811576101888096]
    },
    {
      "id": "six_dimensional",
      "p": [0.11, -0.07, 0.05, 0.09, -0.03, 0.04],
      "v": [0.21, -0.02, 0.08, 0.12, -0.01, 0.07],
      "expected": [0.3054212458238428, -0.09238934688078035, 0.12495996963896026, 0.2033919599726248, -0.04087733826899537, 0.10535197205554413]
    }
  ]
}
