{
  "version": "1.0.0",
  "metric": "mobius_addition",
  "formula": "u (+) v = ((1 + 2<u,v> + ||v||^2) u + (1 - ||u||^2) v) / (1 + 2<u,v> + ||u||^2 ||v||^2)",
