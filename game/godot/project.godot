; Spiral Forge RPG — Godot 4 Project Configuration
; Engine: Godot 4 with GridMap for 3D tile-based levels
; Framework: SCBE-AETHERMOORE Six Sacred Tongues

[application]

config/name="Spiral Forge"
config/description="A distributed-systems fantasy action RPG with creature fleets and branching evolutions."
config/version="0.2.0"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/ui/icon.svg"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
TongueSystem="*res://scripts/autoload/tongue_system.gd"
GameState="*res://scripts/autoload/game_state.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="forward_plus"

