<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0</Version>
  <ProviderName>SCBE-AETHERMOORE</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="SCBE Writer"/>
  <Description DefaultValue="AI writing terminal for Microsoft Word — Claude-powered manuscript editor"/>
  <IconUrl DefaultValue="https://localhost:3000/taskpane/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/taskpane/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/issdandavis/SCBE-AETHERMOORE"/>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="getStartedTitle"/>
            <Description resid="getStartedDesc"/>
            <LearnMoreUrl resid="learnMoreUrl"/>
          </GetStarted>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="SCBEGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="SCBEWriterButton">
                  <Label resid="buttonLabel"/>
                  <Supertip>
                    <Title resid="buttonLabel"/>
                    <Description resid="buttonTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>SCBEWriterPane</TaskpaneId>
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://localhost:3000/taskpane/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://localhost:3000/taskpane/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://localhost:3000/taskpane/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://localhost:3000/taskpane/taskpane.html"/>
        <bt:Url id="learnMoreUrl" DefaultValue="https://github.com/issdandavis/SCBE-AETHERMOORE"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="getStartedTitle" DefaultValue="SCBE Writer"/>
        <bt:String id="groupLabel" DefaultValue="SCBE"/>
        <bt:String id="buttonLabel" DefaultValue="AI Writer"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="getStartedDesc" DefaultValue="AI writing terminal for your manuscript"/>
        <bt:String id="buttonTip" DefaultValue="Open the AI writing terminal sidebar"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
