                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ records: [{ fields: { Name: $(\u0027Prepare M5 Payload\u0027).item.json.event_type + \u0027 :: \u0027 + $(\u0027Prepare M5 Payload\u0027).item.json.record_id, Description: $(\u0027Prepare M5 Payload\u0027).item.json.summary, Status: \u0027In Progress\u0027, \u0027Priority Level\u0027: \u0027Medium\u0027, \u0027Estimated Hours\u0027: 1, \u0027Created Date\u0027: new Date().toISOString() } }] }) }}",
                                         "options":  {
                                                         "timeout":  15000
                                                     }
                                     },
                      "id":  "airtable_log",
                      "name":  "Airtable: Log Event",
