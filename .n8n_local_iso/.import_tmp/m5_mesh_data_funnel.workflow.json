                                         "responseMode":  "responseNode",
                                         "options":  {

                                                     }
                                     },
                      "id":  "webhook_trigger",
                      "name":  "Webhook: M5 Intake",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       -920,
                                       220
                                   ],
                      "webhookId":  "scbe-m5-funnel-001"
                  },
                  {
                      "parameters":  {
                                         "rule":  {
                                                      "interval":  [
                                                                       {
                                                                           "field":  "hours",
                                                                           "hoursInterval":  2
                                                                       }
                                                                   ]
                                                  }
                                     },
                      "id":  "schedule_trigger",
                      "name":  "Schedule: M5 Sweep",
                      "type":  "n8n-nodes-base.scheduleTrigger",
                      "typeVersion":  1.2,
                      "position":  [
                                       -920,
                                       -20
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const input = $json || {};\nconst nowIso = new Date().toISOString();\nconst summary = input.summary || input.text || input.context || \u0027m5 mesh intake event\u0027;\nconst tongue = (input.tongue || \u0027KO\u0027).toUpperCase();\nconst eventType = input.event_type || input.eventType || \u0027mesh_intake\u0027;\nconst source = input.source || input.source_system || \u0027n8n\u0027;\n\nconst metadata = {\n  run_id: input.run_id || `m5-${Date.now()}`,\n  source_system: source,\n  mesh_node: input.mesh_node || \u0027m5.funnel.intake\u0027,\n  decision_hint: input.decision || \u0027UNKNOWN\u0027,\n  published_at_utc: nowIso,\n  confidence: input.confidence ?? null,\n  tags: input.tags || []\n};\n\nreturn [{\n  json: {\n    event_type: eventType,\n    summary,\n    outcome: input.outcome || input.response || \u0027captured\u0027,\n    tongue,\n    source_system: source,\n    record_id: input.record_id || `${source}-${Date.now()}`,\n    metadata\n  }\n}];"
                                     },
                      "id":  "prepare_payload",
                      "name":  "Prepare M5 Payload",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       -660,
                                       120
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "http://localhost:8001/v1/governance/scan",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "X-API-Key",
                                                                                         "value":  "={{ $env.SCBE_API_KEY }}"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ content: $(\u0027Prepare M5 Payload\u0027).item.json.summary, scan_mode: \u0027full\u0027 }) }}",
                                         "options":  {
                                                         "timeout":  10000
                                                     }
                                     },
                      "id":  "governance_scan",
                      "name":  "Governance Scan",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       -380,
                                       120
                                   ]
                  },
                  {
                      "parameters":  {
                                         "conditions":  {
                                                            "options":  {
                                                                            "caseSensitive":  false
                                                                        },
                                                            "conditions":  [
                                                                               {
                                                                                   "leftValue":  "={{ $json.verdict || $json.governance_decision || \u0027ALLOW\u0027 }}",
                                                                                   "rightValue":  "DENY",
                                                                                   "operator":  {
                                                                                                    "type":  "string",
                                                                                                    "operation":  "notEquals"
                                                                                                }
                                                                               }
                                                                           ],
                                                            "combinator":  "and"
                                                        }
                                     },
                      "id":  "governance_gate",
                      "name":  "Governance Gate",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2,
                      "position":  [
                                       -120,
                                       120
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "http://localhost:8001/v1/training/ingest",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "X-API-Key",
                                                                                         "value":  "={{ $env.SCBE_API_KEY }}"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ event_type: $(\u0027Prepare M5 Payload\u0027).item.json.event_type, context: $(\u0027Prepare M5 Payload\u0027).item.json.summary, outcome: $(\u0027Prepare M5 Payload\u0027).item.json.outcome, tongue: $(\u0027Prepare M5 Payload\u0027).item.json.tongue, metadata: $(\u0027Prepare M5 Payload\u0027).item.json.metadata }) }}",
                                         "options":  {
                                                         "timeout":  15000
                                                     }
                                     },
                      "id":  "training_ingest",
                      "name":  "Training Ingest",
