                                   ],
                      "parameters":  {
                                         "functionCode":  "return {\n  rss_item: \n`\u003citem\u003e\n  \u003ctitle\u003e${item.title}\u003c/title\u003e\n  \u003clink\u003e${item.link}\u003c/link\u003e\n  \u003cdescription\u003e${item.description}\u003c/description\u003e\n  \u003cpubDate\u003e${item.date}\u003c/pubDate\u003e\n\u003c/item\u003e`\n}"
