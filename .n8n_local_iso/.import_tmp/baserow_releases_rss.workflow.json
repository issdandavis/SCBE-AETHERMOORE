                      "type":  "n8n-nodes-base.function",
                      "position":  [
                                       900,
                                       500
                                   ],
                      "parameters":  {
                                         "functionCode":  "let feed =\n`\u003c?xml version=\"1.0\" encoding=\"UTF-8\" ?\u003e\n\u003crss version=\"2.0\"\u003e\n\n\u003cchannel\u003e\n  \u003ctitle\u003eBaserow Releases\u003c/title\u003e\n  \u003clink\u003ehttps://baserow.io/blog/category/release\u003c/link\u003e\n  \u003cdescription\u003eStay up to date with the latest changes and updates of Baserow\u003c/description\u003e\n  ${items.map(e =\u003e e.json.rss_item).join(\u0027\\n\u0027)}\n\u003c/channel\u003e\n\n\u003c/rss\u003e`;\n\nreturn [{\n  json: {\n    feed: feed\n  }\n}];"
                                     },
                      "typeVersion":  1
                  },
