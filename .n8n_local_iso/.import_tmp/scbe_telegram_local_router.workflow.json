                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "={{ \u0027https://api.telegram.org/bot\u0027 + $env.TELEGRAM_BOT_TOKEN + \u0027/sendMessage\u0027 }}",
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ chat_id: $(\u0027Parse Telegram Command\u0027).item.json.chat_id, text: $json.text }) }}",
                                         "options":  {
                                                         "timeout":  20000
                                                     }
                                     }
                  }
