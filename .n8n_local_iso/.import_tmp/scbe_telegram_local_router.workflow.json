{
    "name":  "SCBE Telegram Local Router",
    "nodes":  [
                  {
                      "id":  "tg_trigger",
                      "name":  "Telegram Trigger",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2.1,
                      "position":  [
                                       220,
                                       280
                                   ],
                      "parameters":  {
                                         "httpMethod":  "POST",
                                         "path":  "telegram-local-router",
                                         "responseMode":  "onReceived",
                                         "options":  {

                                                     }
                                     }
                  },
                  {
                      "id":  "parse_cmd",
                      "name":  "Parse Telegram Command",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       460,
                                       280
                                   ],
                      "parameters":  {
                                         "jsCode":  "const update = $json.body || $json;\nconst message = update.message || update.edited_message || update.channel_post || {};\nconst chatId = message.chat?.id ?? null;\nif (!chatId) {\n  return [];\n}\n\nconst msg = String(message.text || \u0027\u0027).trim();\nlet mode = \u0027dispatch\u0027;\nlet provider = \u0027huggingface\u0027;\nlet prompt = msg;\nconst lower = msg.toLowerCase();\n\nif (lower === \u0027/status\u0027) {\n  mode = \u0027status\u0027;\n  prompt = \u0027status\u0027;\n} else if (lower.startsWith(\u0027/grok \u0027)) {\n  provider = \u0027xai\u0027;\n  prompt = msg.slice(6).trim();\n} else if (lower.startsWith(\u0027/claude \u0027)) {\n  provider = \u0027anthropic\u0027;\n  prompt = msg.slice(8).trim();\n} else if (lower.startsWith(\u0027/gpt \u0027)) {\n  provider = \u0027openai\u0027;\n  prompt = msg.slice(5).trim();\n} else if (lower.startsWith(\u0027/hf \u0027)) {\n  provider = \u0027huggingface\u0027;\n  prompt = msg.slice(4).trim();\n}\n\nif (!prompt) {\n  prompt = \u0027hello\u0027;\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    mode,\n    provider,\n    prompt,\n    original: msg,\n    update_id: update.update_id || null\n  }\n}];"
                                     }
                  },
                  {
                      "id":  "is_status",
                      "name":  "Is Status?",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2.2,
                      "position":  [
                                       700,
                                       280
                                   ],
                      "parameters":  {
                                         "conditions":  {
                                                            "options":  {
                                                                            "version":  2,
                                                                            "leftValue":  "",
                                                                            "caseSensitive":  false,
                                                                            "typeValidation":  "strict"
                                                                        },
                                                            "combinator":  "and",
                                                            "conditions":  [
                                                                               {
                                                                                   "id":  "mode_check",
                                                                                   "leftValue":  "={{ $json.mode }}",
                                                                                   "rightValue":  "status",
                                                                                   "operator":  {
                                                                                                    "type":  "string",
                                                                                                    "operation":  "equals"
                                                                                                }
                                                                               }
                                                                           ]
                                                        },
                                         "options":  {

                                                     }
                                     }
                  },
                  {
                      "id":  "status_call",
                      "name":  "Bridge Providers Status",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       940,
                                       160
                                   ],
                      "parameters":  {
                                         "method":  "GET",
                                         "url":  "={{ ($env.SCBE_BRIDGE_URL || \u0027http://127.0.0.1:8002\u0027) + \u0027/v1/llm/providers\u0027 }}",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "X-API-Key",
                                                                                         "value":  "={{ $env.SCBE_API_KEY || \u0027scbe-dev-key\u0027 }}"
                                                                                     }
                                                                                 ]
                                                              },
                                         "options":  {
                                                         "timeout":  20000
                                                     }
                                     }
                  },
                  {
                      "id":  "status_text",
                      "name":  "Build Status Reply",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1160,
                                       160
                                   ],
                      "parameters":  {
                                         "jsCode":  "const p = $json.providers || {};\nconst line = (k, v) =\u003e `${k}: ${v?.configured ? \u0027on\u0027 : \u0027off\u0027} (${v?.default_model || \u0027-\u0027})`;\nconst text = [\n  \u0027SCBE Provider Status\u0027,\n  line(\u0027openai\u0027, p.openai),\n  line(\u0027anthropic\u0027, p.anthropic),\n  line(\u0027xai\u0027, p.xai),\n  line(\u0027huggingface\u0027, p.huggingface),\n  `zapier: ${$json.zapier?.configured ? \u0027on\u0027 : \u0027off\u0027}`\n].join(\u0027\\n\u0027);\nreturn [{ json: { text } }];"
                                     }
                  },
                  {
                      "id":  "status_send",
                      "name":  "Telegram Reply Status",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1380,
                                       160
                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "={{ \u0027https://api.telegram.org/bot\u0027 + $env.TELEGRAM_BOT_TOKEN + \u0027/sendMessage\u0027 }}",
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ chat_id: $(\u0027Parse Telegram Command\u0027).item.json.chat_id, text: $json.text }) }}",
                                         "options":  {
                                                         "timeout":  20000
                                                     }
                                     }
                  },
                  {
                      "id":  "dispatch_call",
                      "name":  "Bridge LLM Dispatch",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       940,
                                       380
                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "={{ ($env.SCBE_BRIDGE_URL || \u0027http://127.0.0.1:8002\u0027) + \u0027/v1/llm/dispatch\u0027 }}",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "X-API-Key",
                                                                                         "value":  "={{ $env.SCBE_API_KEY || \u0027scbe-dev-key\u0027 }}"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ provider: $json.provider, messages: [{ role: \u0027user\u0027, content: $json.prompt }], temperature: 0.2, max_tokens: 700, metadata: { source: \u0027telegram\u0027, workflow: \u0027scbe_telegram_local_router\u0027 } }) }}",
                                         "options":  {
                                                         "timeout":  90000
                                                     }
                                     }
                  },
                  {
                      "id":  "dispatch_text",
                      "name":  "Build Dispatch Reply",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1160,
                                       380
                                   ],
                      "parameters":  {
                                         "jsCode":  "let text = String($json.text || \u0027\u0027).trim();\nif (!text) {\n  text = \u0027No text response from provider.\u0027;\n}\nif (text.length \u003e 3500) {\n  text = text.slice(0, 3500) + \u0027\\n...[truncated]\u0027;\n}\nreturn [{ json: { text } }];"
                                     }
                  },
