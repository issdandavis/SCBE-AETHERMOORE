    "afterFileEdit": [
      {
        "command": "python .cursor/hooks/after_file_edit.py",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "subagentStart": [
      {
        "command": "python .cursor/hooks/subagent_start.py",
        "timeout": 8,
        "failClosed": false
      }
    ],
    "subagentStop": [
