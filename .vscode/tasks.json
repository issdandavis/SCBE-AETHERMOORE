{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build TypeScript",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Watch TypeScript",
      "type": "npm",
      "script": "build:watch",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Type Check",
      "type": "npm",
      "script": "typecheck",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run Python Tests",
      "type": "shell",
      "command": "pytest",
      "args": ["tests/", "-v", "--cov=src", "--cov-report=html"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run TypeScript Tests",
      "type": "npm",
      "script": "test",
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run All Tests",
      "dependsOn": ["Run Python Tests", "Run TypeScript Tests"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Format Python Code",
      "type": "shell",
      "command": "black",
      "args": ["src/", "tests/"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Format TypeScript Code",
      "type": "shell",
      "command": "npx",
      "args": ["prettier", "--write", "src/**/*.ts", "tests/**/*.ts"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Lint Python",
      "type": "shell",
      "command": "flake8",
      "args": ["src/", "tests/", "--max-line-length=120"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run SCBE CLI",
      "type": "shell",
      "command": "python",
      "args": ["scbe-cli.py"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "Package NPM",
      "type": "npm",
      "script": "package",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Clean Build",
      "type": "npm",
      "script": "clean",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Full Build Pipeline",
      "dependsOn": ["Clean Build", "Type Check", "Build TypeScript", "Run All Tests"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Open Customer Demo",
      "type": "shell",
      "command": "start",
      "args": ["scbe-aethermoore/customer-demo.html"],
      "windows": {
        "command": "start",
        "args": ["scbe-aethermoore/customer-demo.html"]
      },
      "linux": {
        "command": "xdg-open",
        "args": ["scbe-aethermoore/customer-demo.html"]
      },
      "osx": {
        "command": "open",
        "args": ["scbe-aethermoore/customer-demo.html"]
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "SCBE: Kaggle Approval V2 Ready",
      "type": "npm",
      "script": "training:kaggle:approval-v2:ready",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "SCBE: Kaggle Approval V2 Pattern Score",
      "type": "shell",
      "command": "npm run training:kaggle:patterns -- --round coding-approval-metrics-v2",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "SCBE: Kaggle Approval V2 Launch",
      "type": "npm",
      "script": "training:kaggle:approval-v2:launch",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    },
    {
      "label": "SCBE: Kaggle Active Status",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "kaggle kernels status issacizrealdavis/polly-auto-regularized-coding-v8; kaggle kernels status issacizrealdavis/polly-auto-dsl-syn-v2"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "SCBE: Kaggle DSL V3 Fast Ready",
      "type": "shell",
      "command": "python scripts\\kaggle_auto\\launch.py --round dsl-synthesis-v3-fast --gpu t4 --ready",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "SCBE: Kaggle DSL V3 Fast Launch",
      "type": "shell",
      "command": "python scripts\\kaggle_auto\\launch.py --round dsl-synthesis-v3-fast --gpu t4",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    },
    {
      "label": "SCBE: Frozen Eval Fresh HF v7",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/eval/score_adapter_frozen.py",
        "--adapter",
        "issdandavis/scbe-coding-agent-qwen-stage6-repair-v7-hfjobs",
        "--per-file-limit",
        "5",
        "--max-length",
        "1024"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "SCBE: Functional Benchmark Fresh HF v7",
      "type": "shell",
      "command": "npm run benchmark:coding-agents -- --models BASE issdandavis/scbe-coding-agent-qwen-stage6-repair-v7-hfjobs --max-new-tokens 220",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "SCBE: Gate Latest Functional Benchmark",
      "type": "shell",
      "command": "npm run benchmark:coding-agents:gate -- artifacts\\coding_agent_benchmarks\\latest\\report.json --adapter issdandavis/scbe-coding-agent-qwen-stage6-repair-v7-hfjobs --min-pass-rate 0.85 --beat-base",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "SCBE: AgentBus Deployment Check",
      "type": "shell",
      "command": "npm run agentbus:deployment-check",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "SCBE: AgentBus Deployment Check Ollama Smoke",
      "type": "shell",
      "command": "npm run agentbus:deployment-check:ollama",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    },
    {
      "label": "SCBE: AgentBus Switchboard Dry Run",
      "type": "shell",
      "command": "npm run agentbus:switchboard:dry",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "SCBE: AgentBus Switchboard",
      "type": "shell",
      "command": "npm run agentbus:switchboard",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
