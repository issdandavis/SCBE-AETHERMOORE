{
  "name": "scbe-aethermoore-cli",
  "version": "4.4.0",
  "description": "Standalone CLI for SCBE-AETHERMOORE: natural-language command resolver with autocorrect ledger, GeoSeal tools, flow operator loop, liboqs proof receipts, bus workspace suite, agent-bus passthrough, tokenizer lanes, governance abacus (BigInt L12+L13), SCONE-class Solidity contract scanner, trap-in-good-loops dispatcher.",
  "author": "Issac Daniel Davis <issdandavis@gmail.com>",
  "license": "MIT OR Apache-2.0",
  "type": "commonjs",
  "bin": {
    "scbe": "bin/scbe.js",
    "geoseal": "bin/scbe.js",
    "scbe-geoseal": "bin/scbe.js"
  },
  "files": [
    "bin",
    "scripts/scbe_tb_agent.py",
    "scripts/shell_benchmark.cjs",
    "tests",
    "README.md",
    "LICENSE",
    "LICENSE-APACHE",
    "LICENSE-NOTICE.md"
  ],
  "scripts": {
    "help": "node ./bin/scbe.js --help",
    "selftest": "node ./bin/scbe.js selftest",
    "test": "node --test tests/*.test.cjs",
    "bench:shell": "node scripts/shell_benchmark.cjs",
    "pack:dry": "npm pack --dry-run --json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ink": "^4.4.1",
    "react": "^18.3.1",
    "scbe-aethermoore": "^4.1.0",
    "scbe-agent-bus": "^0.4.0"
  },
  "keywords": [
    "scbe",
    "aethermoore",
    "cli",
    "geoseal",
    "tokenizer",
    "governance",
    "sacred-tongues",
    "agent-tools",
    "dimensional-analysis",
    "agent-bus",
    "workflow",
    "operator-loop",
    "agent-orchestration",
    "ai-safety"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/issdandavis/SCBE-AETHERMOORE.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/issdandavis/SCBE-AETHERMOORE/issues"
  },
  "homepage": "https://github.com/issdandavis/SCBE-AETHERMOORE#readme",
