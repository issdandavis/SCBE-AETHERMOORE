# SpiralWord App Configuration
# =============================
# Copy to .env and fill in values. Never commit real keys.

# Server
SPIRALWORD_HOST=0.0.0.0
SPIRALWORD_PORT=8000

# AI Provider Keys (pluggable ports)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
CUSTOM_AI_ENDPOINT=

# SCBE Governance
SCBE_SECRET_KEY=change-me-in-production
SCBE_NONCE_MAX_SIZE=10000
SCBE_NONCE_USE_BLOOM=false
SCBE_REPLAY_WINDOW_SECONDS=300
SCBE_PQC_ENABLED=false

# Storage (extend to DynamoDB / Redis)
STORAGE_BACKEND=memory
