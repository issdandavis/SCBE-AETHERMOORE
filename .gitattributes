* text=auto

# Prettier/Black/Ruff/flake8-managed source and docs use LF everywhere.
.editorconfig text eol=lf
.gitattributes text eol=lf
.prettierignore text eol=lf
.prettierrc text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
