{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scbe://schemas/agent_endurance_taskset_v1.schema.json",
  "title": "SCBE Agent Endurance Taskset v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "taskset_id",
    "regimen_id",
    "created_at_utc",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "scbe_agent_endurance_taskset_v1"
    },
    "taskset_id": {
      "type": "string",
      "minLength": 3
    },
    "regimen_id": {
      "type": "string",
      "minLength": 3
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 10
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "phase_id",
          "task_type",
          "prompt",
          "time_budget_seconds",
          "scoring"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "phase_id": {
            "type": "string",
            "minLength": 1
          },
          "task_type": {
            "type": "string",
            "enum": ["known_answer", "open_ended", "project_checkpoint", "defense"]
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard", "expert"]
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "time_budget_seconds": {
            "type": "integer",
            "minimum": 30
          },
          "tool_budget": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "max_tool_calls": { "type": "integer", "minimum": 0 },
              "max_network_calls": { "type": "integer", "minimum": 0 }
            }
          },
          "ground_truth": {
            "type": ["object", "null"],
            "additionalProperties": true
          },
          "scoring": {
            "type": "object",
            "additionalProperties": false,
            "required": ["method"],
            "properties": {
              "method": {
                "type": "string",
                "enum": ["exact_match", "unit_tests", "rubric", "hybrid"]
              },
              "rubric": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["criterion", "max_points"],
                  "properties": {
                    "criterion": { "type": "string", "minLength": 1 },
                    "max_points": { "type": "number", "minimum": 0 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
