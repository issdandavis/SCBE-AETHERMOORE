{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scbe.local/schemas/academy_lesson.schema.json",
  "title": "AetherDesk Academy Lesson",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "path", "world", "objective", "concepts", "starter_files", "tests", "ai_pal_policy"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
    "title": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "world": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "concepts": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "starter_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "content": {"type": "string"},
          "language": {"type": "string"}
        }
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "command"],
        "properties": {
          "kind": {"type": "string", "enum": ["pytest", "node", "cargo", "go", "scbe", "browser", "custom"]},
          "command": {"type": "string", "minLength": 1},
          "timeout_ms": {"type": "integer", "minimum": 1000, "maximum": 120000},
          "expected_exit_code": {"type": "integer", "default": 0}
        }
      }
    },
    "allowed_commands": {"type": "array", "items": {"type": "string"}},
    "hints": {"type": "array", "items": {"type": "string"}},
    "ai_pal_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "patch_requires_user_request"],
      "properties": {
        "default": {"type": "string", "enum": ["socratic", "explain", "inspect", "patch", "run", "reflect"]},
        "patch_requires_user_request": {"type": "boolean"},
        "autonomous_repair_allowed": {"type": "boolean", "default": false},
        "allowed_modes": {
          "type": "array",
          "items": {"type": "string", "enum": ["socratic", "explain", "inspect", "patch", "run", "reflect"]}
        }
      }
    },
    "training_tags": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}}
  }
}
