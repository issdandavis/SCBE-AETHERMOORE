{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scbe://schemas/swle/swle_lexicon_entry.schema.json",
  "title": "SWLE Multilingual Lexicon Entry",
  "description": "Row schema for one lexical entry used in SWLE v0 multilingual experiments. Intended for JSONL datasets.",
  "type": "object",
  "required": [
    "schema_version",
    "entry_id",
    "language",
    "forms",
    "concept",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "entry_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "language": {
      "type": "object",
      "required": [
        "language_id",
        "language_name"
      ],
      "properties": {
        "language_id": {
          "type": "string"
        },
        "language_name": {
          "type": "string"
        },
        "iso_639_3": {
          "type": [
            "string",
            "null"
          ]
        },
        "family": {
          "type": [
            "string",
            "null"
          ]
        },
        "scripts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "forms": {
      "type": "object",
      "required": [
        "surface",
        "normalized",
        "phonemes_ipa"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "normalized": {
          "type": "string",
          "minLength": 1
        },
        "transliteration": {
          "type": [
            "string",
            "null"
          ]
        },
        "graphemes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "phonemes_ipa": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "phoneme_source": {
          "type": "string",
          "enum": [
            "gold_lexicon",
            "manual",
            "g2p",
            "inferred",
            "unknown"
          ]
        },
        "stress_pattern": {
          "type": [
            "string",
            "null"
          ]
        },
        "syllables": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "phonemes"
            ],
            "properties": {
              "phonemes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "stress": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "primary",
                  "secondary",
                  "unstressed",
                  null
                ]
              },
              "role": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "onset",
                  "nucleus",
                  "coda",
                  "mixed",
                  null
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "morphemes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "form"
            ],
            "properties": {
              "form": {
                "type": "string"
              },
              "gloss": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "role": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "bound": {
                "type": [
                  "boolean",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "concept": {
      "type": "object",
      "required": [
        "concept_id",
        "english_gloss",
        "pos"
      ],
      "properties": {
        "concept_id": {
          "type": "string"
        },
        "translation_set_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "english_gloss": {
          "type": "string"
        },
        "glosses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "lang",
              "text"
            ],
            "properties": {
              "lang": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "pos": {
          "type": "string",
          "enum": [
            "noun",
            "verb",
            "adjective",
            "adverb",
            "particle",
            "pronoun",
            "determiner",
            "adposition",
            "numeral",
            "interjection",
            "other"
          ]
        },
        "semantic_domain": {
          "type": [
            "string",
            "null"
          ]
        },
        "sense_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "alignment": {
      "type": "object",
      "properties": {
        "cognate_class_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "etymon_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "borrowed_from": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "semantic_targets": {
      "type": "object",
      "properties": {
        "valence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -1,
          "maximum": 1
        },
        "arousal": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "concreteness": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "imageability": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "frequency_log10": {
          "type": [
            "number",
            "null"
          ]
        },
        "target_source": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "morphology_targets": {
      "type": "object",
      "properties": {
        "lemma": {
          "type": [
            "string",
            "null"
          ]
        },
        "inflectional_features": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          }
        },
        "derivational_family_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "tokenizations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "tokenizer_id",
          "tokens"
        ],
        "properties": {
          "tokenizer_id": {
            "type": "string"
          },
          "tokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "token_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "splits": {
      "type": "object",
      "properties": {
        "recommended_split": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "train",
            "dev",
            "test",
            "ood",
            null
          ]
        },
        "heldout_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "dataset_id",
        "source_label",
        "license"
      ],
      "properties": {
        "dataset_id": {
          "type": "string"
        },
        "source_label": {
          "type": "string"
        },
        "source_record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "license": {
          "type": "string"
        },
        "collector": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
