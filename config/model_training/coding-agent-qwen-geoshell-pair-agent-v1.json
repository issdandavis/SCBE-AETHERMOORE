{
  "schema_version": "scbe_model_training_profile_v1",
  "profile_id": "coding-agent-qwen-geoshell-pair-agent-v1",
  "title": "SCBE coding agent Qwen GeoShell paired-agent v1",
  "description": "Narrow reinforcement adapter that teaches the coding agent to work as a Builder/Navigator pair inside GeoShell, keeping model generation, deterministic tool routing, verification, and apply permission in separate lanes.",
  "backend": "hf-jobs-peft-lora",
  "base_model": "Qwen/Qwen2.5-Coder-0.5B-Instruct",
  "system_prompt": "You are an SCBE-AETHERMOORE GeoShell paired coding agent. Work as a two-agent unit: Builder proposes intent and draft code, Navigator routes deterministic facts, runs verification, and blocks conflicting apply/tool lanes. Use GeoSeal policy before any apply. Exact opcode and system-table facts must come from deterministic tools, not memory.",
  "dataset": {
    "root": "training-data/sft",
    "train_files": [
      "geoshell_pair_agent_v1_train.sft.jsonl"
    ],
    "eval_files": [
      "geoshell_pair_agent_v1_holdout.sft.jsonl"
    ]
  },
  "training": {
    "max_seq_length": 768,
    "lora_rank": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "learning_rate": 0.00012,
    "num_train_epochs": 3,
    "batch_size": 1,
    "gradient_accumulation_steps": 4,
    "warmup_ratio": 0.05,
    "max_steps": 120,
    "max_train_records": 210,
    "max_eval_records": 28,
    "logging_steps": 5,
    "save_steps": 60,
    "save_total_limit": 2,
    "gradient_checkpointing": true,
    "seed": 101,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "output_dir": "training/runs/coding-agent-qwen-geoshell-pair-agent-v1"
  },
  "hub": {
    "token_env": "HF_TOKEN",
    "dataset_repo": "issdandavis/scbe-coding-agent-sft-geoshell-pair-agent-v1",
    "push_adapter": true,
    "adapter_repo": "issdandavis/scbe-coding-agent-qwen-geoshell-pair-agent-v1",
    "push_merged": false,
    "gate_required": true
  },
  "execution": {
    "recommended_target": "hf-jobs",
    "hf_flavor": "t4-small",
    "timeout": "1h",
    "default_emit_path": "artifacts/model_training/coding-agent-qwen-geoshell-pair-agent-v1-train.py"
  },
  "evaluation": {
    "contract_path": "config/model_training/geoshell_pair_agent_eval_contract.json",
    "constrained_gate_scaffold": true,
    "paired_benchmark_gate": "python scripts/benchmark/dual_agent_pair_benchmark.py validate",
    "post_training_gate": "Run paired coding gate plus GeoShell pair-agent eval contract before adding this adapter to any promoted merge."
  }
}
