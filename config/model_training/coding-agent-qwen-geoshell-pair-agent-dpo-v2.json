{
  "schema_version": "scbe_model_training_profile_v1",
  "profile_id": "coding-agent-qwen-geoshell-pair-agent-dpo-v2",
  "title": "SCBE coding agent Qwen GeoShell paired-agent DPO v2",
  "description": "Continuation preference repair over the confirmed DPO v1 adapter. Targets the expanded 8-prompt canary raw misses: ownership/rollback before apply, repo-over-memory lookup, HOLD recovery, and roundtable Recorder evidence.",
  "backend": "hf-jobs-peft-dpo",
  "base_model": "Qwen/Qwen2.5-Coder-0.5B-Instruct",
  "system_prompt": "You are an SCBE-AETHERMOORE GeoShell paired coding agent. Work as Builder and Navigator. Builder proposes intent and owned-file scope. Navigator routes deterministic facts, repo lookup, verification, tests, rollback, Recorder evidence, and the apply gate. Name exact required fields before prose.",
  "dataset": {
    "root": "training-data/dpo",
    "train_files": [
      "geoshell_pair_agent_preference_v1_train.jsonl"
    ],
    "eval_files": []
  },
  "training": {
    "base_adapter_repo": "issdandavis/scbe-coding-agent-qwen-geoshell-pair-agent-dpo-v1",
    "max_seq_length": 768,
    "max_prompt_length": 384,
    "lora_rank": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "learning_rate": 2e-5,
    "beta": 0.1,
    "num_train_epochs": 1,
    "batch_size": 1,
    "gradient_accumulation_steps": 4,
    "warmup_ratio": 0.0,
    "max_steps": 120,
    "max_train_records": 12,
    "logging_steps": 5,
    "save_steps": 120,
    "save_total_limit": 1,
    "gradient_checkpointing": true,
    "seed": 109,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "output_dir": "training/runs/coding-agent-qwen-geoshell-pair-agent-dpo-v2"
  },
  "hub": {
    "token_env": "HF_TOKEN",
    "dataset_repo": "issdandavis/scbe-coding-agent-dpo-geoshell-pair-agent-v2",
    "push_adapter": true,
    "adapter_repo": "issdandavis/scbe-coding-agent-qwen-geoshell-pair-agent-dpo-v2",
    "push_merged": false,
    "gate_required": true
  },
  "execution": {
    "recommended_target": "hf-jobs",
    "hf_flavor": "t4-small",
    "timeout": "2h",
    "default_emit_path": "artifacts/model_training/coding-agent-qwen-geoshell-pair-agent-dpo-v2-train.py"
  },
  "evaluation": {
    "contract_path": "config/model_training/geoshell_pair_agent_eval_contract_v2.json",
    "constrained_gate_scaffold": true,
    "max_new_tokens": 180,
    "post_training_gate": "Run independent expanded GeoShell pair-agent smoke eval; promotion needs raw 8/8, not only scaffolded 8/8."
  }
}
