{
  "schema_version": "scbe_model_training_profile_v1",
  "profile_id": "chemistry-qwen-primary",
  "title": "SCBE Qwen chemistry primary lane",
  "description": "Config-backed QLoRA lane for explicitly teaching chemistry packets, atom conservation, reaction templates, and supporting semantic state structure through the Sacred Tongues drill corpus.",
  "backend": "unsloth-qlora",
  "base_model": "Qwen/Qwen2.5-7B-Instruct",
  "system_prompt": "You are an SCBE Sacred Tongues chemistry tutor and packet solver. Teach chemistry explicitly: reaction classes, atom conservation, stability, product prediction, and dimensional or structural constraints. Preserve canonical packet layouts, stay concise, and do not drift into chatty completion style.",
  "dataset": {
    "root": "training-data/sft",
    "train_files": [
      "chemistry_primary_train.sft.jsonl"
    ],
    "eval_files": [
      "chemistry_primary_holdout.sft.jsonl"
    ]
  },
  "training": {
    "max_seq_length": 4096,
    "lora_rank": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "learning_rate": 0.0002,
    "num_train_epochs": 1,
    "batch_size": 2,
    "gradient_accumulation_steps": 8,
    "warmup_ratio": 0.05,
    "max_steps": -1,
    "packing": true,
    "load_in_4bit": true,
    "optim": "adamw_8bit",
    "weight_decay": 0.01,
    "lr_scheduler_type": "cosine",
    "logging_steps": 25,
    "save_strategy": "steps",
    "save_steps": 100,
    "save_total_limit": 2,
    "dataloader_num_workers": 2,
    "seed": 42,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "output_dir": "training/runs/chemistry-qwen-primary"
  },
  "hub": {
    "token_env": "HF_TOKEN",
    "dataset_repo": "issdandavis/scbe-chemistry-primary-sft",
    "push_adapter": false,
    "adapter_repo": "issdandavis/scbe-chemistry-qwen-primary",
    "push_merged": false
  },
  "execution": {
    "default_emit_path": "artifacts/model_training/chemistry-qwen-primary-train.py",
    "recommended_target": "colab"
  }
}
