{
  "schema_version": "scbe_model_training_profile_v1",
  "profile_id": "aligned-foundations-qwen-primary",
  "title": "SCBE Qwen aligned foundations lane",
  "description": "Config-backed QLoRA lane for aligned primitive representations: math, English, Sacred Tongues lane naming, binary transport framing, chemistry packets, and coding primaries.",
  "backend": "unsloth-qlora",
  "base_model": "Qwen/Qwen2.5-7B-Instruct",
  "system_prompt": "You are an SCBE aligned-foundations tutor. Teach the same concept across mathematics, English, Sacred Tongues lanes, binary transport framing, chemistry packets, and coding primaries. Keep invariants explicit and outputs structured.",
  "dataset": {
    "root": "training-data/sft",
    "train_files": [
      "aligned_foundations_train.sft.jsonl",
      "chemistry_primary_train.sft.jsonl",
      "bijective_codeflow_v1_train.sft.jsonl",
      "drill_langues_full_train.sft.jsonl"
    ],
    "eval_files": [
      "aligned_foundations_holdout.sft.jsonl",
      "chemistry_primary_holdout.sft.jsonl",
      "bijective_codeflow_v1_holdout.sft.jsonl",
      "drill_langues_full_holdout.sft.jsonl"
    ]
  },
  "training": {
    "max_seq_length": 4096,
    "lora_rank": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "learning_rate": 0.0002,
    "num_train_epochs": 1,
    "batch_size": 2,
    "gradient_accumulation_steps": 8,
    "warmup_ratio": 0.05,
    "max_steps": -1,
    "packing": true,
    "load_in_4bit": true,
    "optim": "adamw_8bit",
    "weight_decay": 0.01,
    "lr_scheduler_type": "cosine",
    "logging_steps": 25,
    "save_strategy": "steps",
    "save_steps": 100,
    "save_total_limit": 2,
    "dataloader_num_workers": 2,
    "seed": 42,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "output_dir": "training/runs/aligned-foundations-qwen-primary"
  },
  "hub": {
    "token_env": "HF_TOKEN",
    "dataset_repo": "issdandavis/scbe-aligned-foundations-sft",
    "push_adapter": false,
    "adapter_repo": "issdandavis/scbe-aligned-foundations-qwen-primary",
    "push_merged": false
  },
  "execution": {
    "default_emit_path": "artifacts/model_training/aligned-foundations-qwen-primary-train.py",
    "recommended_target": "colab"
  }
}
