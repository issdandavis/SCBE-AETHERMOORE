{
  "version": 1,
  "runtime": "gpt-example",
  "policy_intents": {
    "destructive_shell_gate": true,
    "network_exfil_awareness": true,
    "secret_leak_guard": true,
    "high_risk_mcp_confirmation": true,
    "tool_audit_logging": true,
    "post_run_summaries": true,
    "file_edit_postcheck_hint": true,
    "subagent_guardrails": true
  },
  "event_mapping": {
    "on_session_start": "sessionStart",
    "on_session_end": "sessionEnd",
    "on_before_shell": "beforeShellExecution",
    "on_after_shell": "afterShellExecution",
    "on_before_mcp": "beforeMCPExecution",
    "on_after_mcp": "afterMCPExecution",
    "on_pre_tool": "preToolUse",
    "on_post_tool": "postToolUse",
    "on_post_tool_failure": "postToolUseFailure",
    "on_before_submit": "beforeSubmitPrompt",
    "on_after_file_edit": "afterFileEdit",
    "on_subagent_start": "subagentStart",
    "on_subagent_stop": "subagentStop"
  },
  "handlers": {
    "beforeShellExecution": ".cursor/hooks/shell_guard.py",
    "beforeMCPExecution": ".cursor/hooks/before_mcp_execution.py",
    "preToolUse": ".cursor/hooks/pre_tool_use.py",
    "beforeSubmitPrompt": ".cursor/hooks/before_submit_prompt.py",
    "afterFileEdit": ".cursor/hooks/after_file_edit.py",
    "subagentStart": ".cursor/hooks/subagent_start.py",
    "postToolUse": ".cursor/hooks/post_tool_use.py",
    "postToolUseFailure": ".cursor/hooks/post_tool_use_failure.py",
    "afterShellExecution": ".cursor/hooks/after_shell_execution.py",
    "afterMCPExecution": ".cursor/hooks/after_mcp_execution.py",
    "subagentStop": ".cursor/hooks/subagent_stop.py",
    "sessionStart": ".cursor/hooks/session_start.py",
    "sessionEnd": ".cursor/hooks/session_end.py"
  },
  "default_policy_mode": "fail_open",
  "notes": [
    "Template only. Replace keys with your GPT runtime event names.",
    "Run in dry-run mode first to confirm payload schemas.",
    "Preserve ask or deny behavior for explicit danger classes."
  ]
}
