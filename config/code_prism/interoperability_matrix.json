{
  "version": "0.2.0",
  "languages": [
    "python",
    "typescript",
    "go",
    "rust",
    "c",
    "julia",
    "haskell"
  ],
  "transpilers": {
    "python": ["python", "typescript", "go", "rust", "c", "julia", "haskell"],
    "typescript": ["python", "typescript", "go", "rust", "c", "julia", "haskell"],
    "go": ["python", "typescript", "go", "rust", "c", "julia", "haskell"],
    "rust": ["python", "typescript", "go", "rust", "c", "julia", "haskell"],
    "c": ["python", "typescript", "go", "rust", "c", "julia", "haskell"],
    "julia": ["python", "typescript", "go", "rust", "c", "julia", "haskell"],
    "haskell": ["python", "typescript", "go", "rust", "c", "julia", "haskell"]
  },
  "conlang_routes": {
    "KO": ["control-flow", "api-contracts"],
    "AV": ["io-serialization", "adapter-edges"],
    "RU": ["policy-and-constraints"],
    "CA": ["computation-and-logic"],
    "UM": ["security-privacy-hardening"],
    "DR": ["types-and-structure"]
  },
  "safe_subset": {
    "supported_constructs": [
      "function_def",
      "arguments",
      "return_statement",
      "basic_assignments",
      "simple_expressions",
      "safe_subset_rust_functions",
      "safe_subset_c_functions",
      "safe_subset_julia_functions",
      "safe_subset_haskell_definitions",
      "safe_subset_go_functions"
    ],
    "deferred_constructs": [
      "classes",
      "generics",
      "decorators",
      "async_await",
      "macros",
      "reflection"
    ]
  }
}

