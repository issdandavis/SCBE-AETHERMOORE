{
  "version": "0.1.0",
  "languages": [
    "python",
    "typescript",
    "go"
  ],
  "transpilers": {
    "python": ["typescript", "go"],
    "typescript": ["python", "go"],
    "go": ["python", "typescript"]
  },
  "conlang_routes": {
    "KO": ["control-flow", "api-contracts"],
    "AV": ["io-serialization", "adapter-edges"],
    "RU": ["policy-and-constraints"],
    "CA": ["computation-and-logic"],
    "UM": ["security-privacy-hardening"],
    "DR": ["types-and-structure"]
  },
  "safe_subset": {
    "supported_constructs": [
      "function_def",
      "arguments",
      "return_statement",
      "basic_assignments",
      "simple_expressions"
    ],
    "deferred_constructs": [
      "classes",
      "generics",
      "decorators",
      "async_await",
      "macros",
      "reflection"
    ]
  },
  "native_systems": {
    "python_runtime": {
      "native_language": "python",
      "default_tongue_combo": "KO+CA+DR",
      "risk_profile": "strict"
    },
    "node_runtime": {
      "native_language": "typescript",
      "default_tongue_combo": "AV+CA+DR",
      "risk_profile": "standard"
    },
    "go_runtime": {
      "native_language": "go",
      "default_tongue_combo": "KO+RU+DR",
      "risk_profile": "strict"
    },
    "mcp_python": {
      "native_language": "python",
      "default_tongue_combo": "RU+UM+DR",
      "risk_profile": "strict"
    },
    "mcp_node": {
      "native_language": "typescript",
      "default_tongue_combo": "RU+CA+DR",
      "risk_profile": "strict"
    }
  },
  "governance": {
    "default_action": "QUARANTINE",
    "allow_requires_clean_validation": true,
    "quarantine_on_deferred_constructs": true
  }
}

