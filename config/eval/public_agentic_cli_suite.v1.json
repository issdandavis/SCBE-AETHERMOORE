      "adapter_status": "planned",
      "required_for_public_all_around_claim": true,
      "run_command": [
        "python",
        "scripts/benchmark/external_agentic_eval_driver.py",
        "--manifest",
        "config/eval/external_agentic_eval_tasks.sample.json",
