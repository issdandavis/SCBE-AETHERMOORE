  },
  "web_research": {
    "topics": [
      "agentic web automation",
      "browser orchestration reliability",
      "workflow governance for ai agents"
    ],
    "max_per_topic": 6,
    "backend": "playwright",
    "max_tabs": 6,
    "query": "",
