{
  "name": "scbe-aethermoore",
  "version": "4.0.3",
  "description": "SCBE-AETHERMOORE: Hyperbolic Geometry-Based Security with 14-Layer Architecture",
  "author": "Issac Daniel Davis <issdandavis@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "geoseal": "bin/geoseal.cjs",
    "scbe-geoseal": "bin/geoseal.cjs"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./harmonic": {
      "types": "./dist/src/harmonic/index.d.ts",
      "import": "./dist/src/harmonic/index.js",
      "require": "./dist/src/harmonic/index.js"
    },
    "./symphonic": {
      "types": "./dist/src/symphonic/index.d.ts",
      "import": "./dist/src/symphonic/index.js",
      "require": "./dist/src/symphonic/index.js"
    },
    "./crypto": {
      "types": "./dist/src/crypto/index.d.ts",
      "import": "./dist/src/crypto/index.js",
      "require": "./dist/src/crypto/index.js"
    },
    "./spiralverse": {
      "types": "./dist/src/spiralverse/index.d.ts",
      "import": "./dist/src/spiralverse/index.js",
      "require": "./dist/src/spiralverse/index.js"
    },
    "./spiralauth": {
      "types": "./dist/src/spiralauth/index.d.ts",
      "import": "./dist/src/spiralauth/index.js",
      "require": "./dist/src/spiralauth/index.js"
    },
    "./tokenizer": {
      "types": "./dist/src/tokenizer/index.d.ts",
      "import": "./dist/src/tokenizer/index.js",
      "require": "./dist/src/tokenizer/index.js"
    },
    "./phdm": {
      "types": "./dist/src/harmonic/phdm.d.ts",
      "import": "./dist/src/harmonic/phdm.js",
      "require": "./dist/src/harmonic/phdm.js"
    },
    "./ai_brain": {
      "types": "./dist/src/ai_brain/index.d.ts",
      "import": "./dist/src/ai_brain/index.js",
      "require": "./dist/src/ai_brain/index.js"
    },
    "./governance": {
      "types": "./dist/src/governance/index.d.ts",
      "import": "./dist/src/governance/index.js",
      "require": "./dist/src/governance/index.js"
    }
  },
  "files": [
    "bin",
    "dist/src",
    "dist/packages",
    "README.md",
    "LICENSE",
    "examples/npm"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "clean:release": "node scripts/npm_prepublish_cleanup.js",
    "build": "npm run clean && npm run build:src",
    "build:src": "tsc -p tsconfig.json && node scripts/write_root_index_dts.mjs",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:python": "pytest tests/ -v",
    "test:rust": "cargo test --manifest-path rust/scbe_core/Cargo.toml",
    "test:all": "npm test && npm run test:python",
    "typecheck": "tsc --noEmit",
    "check:circular": "madge --circular --extensions ts src/",
    "check:deps": "madge --extensions ts src/ --image dependency-graph.svg",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:python": "black src/ tests/",
    "lint": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:python": "flake8 src/ tests/",
    "docs:format": "python scripts/format_doc_markdown.py docs/specs docs/proposals --write",
    "docs:check": "python scripts/format_doc_markdown.py docs/specs docs/proposals --check",
    "cli": "python scbe-cli.py",
    "codeprism:build": "python scripts/code_prism_build.py",
    "codeprism:mesh": "python scripts/code_prism_build.py --mesh",
    "connector:health": "python scripts/connector_health_check.py",
    "scbe:bootstrap": "node scripts/scbe_bootstrap.mjs",
    "system:cli": "python scripts/scbe-system-cli.py",
    "training:terminal": "python scripts/system/training_terminal.py",
    "training:merge-adapters": "python scripts/system/merge_lora_adapters.py",
    "training:dispatch-coding-agent": "python scripts/system/dispatch_coding_agent_hf_job.py",
    "training:geoseal-coder": "python scripts/system/geoseal_coding_training_system.py",
    "cash:sprint": "python scripts/revenue/daily_cash_sprint.py",
    "cash:sprint:run": "python scripts/revenue/daily_cash_sprint.py --continuous",
    "cash:sprint:watch": "python scripts/revenue/daily_cash_sprint.py --continuous --cycle-when-complete --max-steps 1",
    "feature:explore": "python scripts/explore_scbe_feature_space.py",
    "eval:legacy:hf": "python scripts/run_legacy_hf_eval.py",
    "probe:attention:fft": "python scripts/probe_attention_fft.py",
    "probe:attention:fft:live": "python scripts/run_attention_fft_probe.py",
    "probe:attention:thermal": "python scripts/probe_thermal_mirror.py",
    "probe:attention:thermal:live": "python scripts/run_thermal_mirror_probe.py",
    "aetherbrowser:model:cli": "python scripts/system/aetherbrowser_model_cli.py",
    "aetherbrowser:service:start": "node ./scripts/system/start_aetherbrowser_extension_service.mjs",
    "aetherbrowser:service:verify": "python scripts/verify_aetherbrowser_extension_service.py --run-backend-smoke",
    "aetherbrowser:service:stop": "node ./scripts/system/stop_aetherbrowser_extension_service.mjs",
    "m6:train": "python scripts/train_m6_spheremesh.py",
    "demo": "npx open-cli scbe-aethermoore/customer-demo.html",
    "agentic:demo": "ts-node src/agentic/demo-runner.ts",
    "game:debug-ts": "node scripts/run_typescript_debug_scenario.cjs",
    "benchmark:coding-agents": "python scripts/eval/functional_coding_agent_benchmark.py",
    "benchmark:coding-agents:college": "python scripts/eval/functional_coding_agent_benchmark.py --task-file config/training/coding_agent_benchmarks/college_choice_eval_tasks_v1.json --replace-default-tasks",
    "benchmark:coding-agents:college:gold": "python scripts/eval/functional_coding_agent_benchmark.py --candidate-file config/training/coding_agent_benchmarks/college_choice_candidate_template_v1.json --task-file config/training/coding_agent_benchmarks/college_choice_eval_tasks_v1.json --replace-default-tasks",
    "benchmark:coding-agents:compare": "python scripts/eval/compare_functional_benchmark_reports.py",
    "benchmark:coding-agents:gate": "python scripts/eval/gate_functional_benchmark.py",
    "training:adapter-registry": "python scripts/model_training/build_adapter_registry.py",
    "training:lora-drift": "python scripts/eval/analyze_lora_drift.py --use-registry",
    "training:curve": "python scripts/eval/analyze_training_curve.py",
    "eval:dsl-v8-suite": "python scripts/eval/run_dsl_v8_eval_suite.py",
    "agent:coding-router:list": "python scripts/agents/coding_agent_router.py --list",
    "agent:coding-router:serve": "python scripts/agents/coding_agent_router.py --serve",
    "training:kaggle:approval-v2:ready": "python scripts/kaggle_auto/launch.py --round coding-approval-metrics-v2 --gpu t4 --ready",
    "training:kaggle:approval-v2:launch": "python scripts/kaggle_auto/launch.py --round coding-approval-metrics-v2 --gpu t4",
    "docker:build": "docker build -t scbe-aethermoore:latest .",
    "docker:run": "docker run -it scbe-aethermoore:latest",
    "docker:compose": "docker-compose up -d",
    "docker:doctor:api": "node ./scripts/scbe_docker_status.mjs --Action doctor --Stack api",
    "docker:doctor:unified": "node ./scripts/scbe_docker_status.mjs --Action doctor --Stack unified",
    "docker:up:api": "node ./scripts/scbe_docker_status.mjs --Action up --Stack api",
    "docker:up:unified": "node ./scripts/scbe_docker_status.mjs --Action up --Stack unified",
    "docker:down:api": "node ./scripts/scbe_docker_status.mjs --Action down --Stack api",
    "docker:down:unified": "node ./scripts/scbe_docker_status.mjs --Action down --Stack unified",
    "docker:status:all": "node ./scripts/scbe_docker_status.mjs --InspectStacks",
    "mcp:doctor": "node ./scripts/scbe_mcp_terminal.mjs --Action doctor",
    "mcp:servers": "node ./scripts/scbe_mcp_terminal.mjs --Action servers",
    "mcp:tools": "node ./scripts/scbe_mcp_terminal.mjs --Action tools",
    "mcp:gateway": "node ./scripts/scbe_mcp_terminal.mjs --Action gateway",
    "publish:prepare": "npm run clean:release && npm run build",
    "publish:pack:json": "node -e \"require('fs').mkdirSync('artifacts/npm-pack',{recursive:true})\" && npm pack --dry-run --json --ignore-scripts --cache ./.npm-cache > artifacts/npm-pack/pack.json",
    "publish:check:strict": "npm run publish:pack:json && node scripts/npm_pack_guard.js --pack-json artifacts/npm-pack/pack.json",
    "publish:pypi:build": "python -m build --sdist --wheel --outdir artifacts/pypi-dist",
    "publish:pypi:check": "python scripts/pypi_dist_guard.py --dist-dir artifacts/pypi-dist",
    "prepublishOnly": "npm run publish:prepare",
    "prepack": "npm run publish:check:strict",
    "package": "npm pack",
    "publish:check": "bash scripts/npm_publish_check.sh",
    "publish:dryrun": "npm pack --dry-run --json",
    "notion:sync": "node scripts/notion-sync.js --all",
    "version:bump": "node scripts/version-bump.js",
    "precommit:check": "bash scripts/pre-commit-check.sh",
    "gateway:serve": "node dist-gateway/gateway/authorize-service.js",
    "gateway:build": "tsc -p tsconfig.gateway.json",
    "xops:dryrun": "node scripts/system/x_ops_queue_runner.mjs --queue workflows/n8n/x_ops_queue.sample.json --dry-run",
    "xops:run": "node scripts/system/x_ops_queue_runner.mjs --queue workflows/n8n/x_ops_queue.sample.json",
    "skills:bridge": "node scripts/system/scbe_skill_tool_bridge.mjs --action quick",
    "skills:bridge:full": "node scripts/system/scbe_skill_tool_bridge.mjs --action full"
  },
  "keywords": [
    "cryptography",
    "security",
    "hyperbolic-geometry",
    "poincare-ball",
    "scbe",
    "aethermoore",
    "quantum-resistant",
    "14-layer-architecture",
    "harmonic-scaling",
    "patent-pending"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/issdandavis/SCBE-AETHERMOORE.git"
  },
  "bugs": {
    "url": "https://github.com/issdandavis/SCBE-AETHERMOORE/issues"
  },
  "homepage": "https://github.com/issdandavis/SCBE-AETHERMOORE#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.6.0",
    "@notionhq/client": "^5.9.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "fast-check": "^4.6.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "ws": "^8.20.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.1",
    "typescript": "^6.0.2"
  }
}
