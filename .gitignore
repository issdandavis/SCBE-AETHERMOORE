# =============================================================================
# SCBE-AETHERMOORE PUBLIC REPO .gitignore
# =============================================================================
# This file ensures private/sensitive content stays out of the public repo.
# Companion private repo: https://github.com/issdandavis/SCBE-private
# =============================================================================

# ---------------------------------------------------------------------------
# PRIVATE DATA — synced to SCBE-private repo instead
# ---------------------------------------------------------------------------

# Training data (SFT pairs, JSONL datasets, game sessions, audio stems)
training-data/

# Training pipeline (raw lore drops, ingest files, verbatim files, runs)
training/

# ---------------------------------------------------------------------------
# Secrets and environment files
# ---------------------------------------------------------------------------
.env
.env.*
!.env.template
!.env.example
deploy/.env
deploy/.env.*
!deploy/.env.template

# AWS / cloud credentials
trust-policy.json
credentials.json
*.pem
*.key

# ---------------------------------------------------------------------------
# Audio / binary / large files
# ---------------------------------------------------------------------------
*.wav
*.mp3
*.flac
*.ogg
*.aac
*.m4a

# Model weights and binary artifacts
*.npz
*.pkl
*.bin
*.onnx
*.pt
*.pth
*.safetensors
*.gguf

# ---------------------------------------------------------------------------
# Everweave exports
# ---------------------------------------------------------------------------
everweave_export/
**/everweave_export/

# ---------------------------------------------------------------------------
# OneDrive / personal file paths
# ---------------------------------------------------------------------------
OneDrive/
**/OneDrive/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.coverage
coverage.json
htmlcov/
*.egg-info/
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.venv/
venv/
.python-version

# ---------------------------------------------------------------------------
# Node / frontend
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/
dist/
release/
build/
coverage/
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Test artifacts
# ---------------------------------------------------------------------------
**/pytest_tmp/
artifacts/pytest_tmp/
artifacts/test_swarm_hub/
tests/test_telemetry_*.json
tests/test_artifacts/
**/test_output.txt

# ---------------------------------------------------------------------------
# Local generated images
# ---------------------------------------------------------------------------
aethermoore_aqm.png
aethermoore_soliton.png

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.dbxignore
.vscode/
.idea/
.DS_Store
Thumbs.db
*.tmp
*.swp
*.swo

# ---------------------------------------------------------------------------
# Kiro MCP Manager
# ---------------------------------------------------------------------------
.kiro/settings/

# ---------------------------------------------------------------------------
# Performance test evidence (hardware-specific)
# ---------------------------------------------------------------------------
docs/evidence/*.json

# ---------------------------------------------------------------------------
# Local databases (except SCBE symphonic_cipher internal ones)
# ---------------------------------------------------------------------------
*.db
!src/symphonic_cipher/**/*.db

# ---------------------------------------------------------------------------
# Claude IDE temp files
# ---------------------------------------------------------------------------
.claude-ide-pads.db-shm
.claude-ide-pads.db-wal

# ---------------------------------------------------------------------------
# Code Prism & connector health (regeneratable)
# ---------------------------------------------------------------------------
artifacts/code_prism/
artifacts/connector_health/

# ---------------------------------------------------------------------------
# Shopify submodule (if pulled)
# ---------------------------------------------------------------------------
shopify/aethermoore-creator-os

# ---------------------------------------------------------------------------
# Misc generated / npm packaging
# ---------------------------------------------------------------------------
.npm-cache-local/
.npm-pack-dryrun.txt
