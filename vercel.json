{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "test \"$VERCEL_GIT_COMMIT_REF\" != \"main\"",
  "builds": [
    {
      "src": "api/agent/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/launch$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/api/agent/(.*)$",
      "dest": "/api/agent/$1.js"
    }
  ]
}
