{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "node scripts/vercel/ignore-build.cjs",
  "builds": [
    {
      "src": "api/agent/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/polly/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/billing/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/launch$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/hire/?$",
      "dest": "/api/agent/hire.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/hire\\.html$",
      "dest": "/api/agent/hire.js"
    },
    {
      "src": "^/hire-b/?$",
      "dest": "/api/agent/hire-b.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/hire-b\\.html$",
      "dest": "/api/agent/hire-b.js"
    },
    {
      "src": "^/products/?$",
      "dest": "/api/agent/products.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/products\\.html$",
      "dest": "/api/agent/products.js"
    },
    {
      "src": "^/start-here/?$",
      "dest": "/api/agent/start-here.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/start-here\\.html$",
      "dest": "/api/agent/start-here.js"
    },
    {
      "src": "^/agents/?$",
      "dest": "/api/agent/agents.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/agents\\.html$",
      "dest": "/api/agent/agents.js"
    },
    {
      "src": "^/chat/?$",
      "dest": "/api/agent/chat-page.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/chat\\.html$",
      "dest": "/api/agent/chat-page.js"
    },
    {
      "src": "^/payments/?$",
      "dest": "/api/agent/payments.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/payments\\.html$",
      "dest": "/api/agent/payments.js"
    },
    {
      "src": "^/workflow-snapshot/?$",
      "dest": "/api/agent/workflow-snapshot.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/workflow-snapshot\\.html$",
      "dest": "/api/agent/workflow-snapshot.js"
    },
    {
      "src": "^/service-credits/?$",
      "dest": "/api/agent/service-credits.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/service-credits\\.html$",
      "dest": "/api/agent/service-credits.js"
    },
    {
      "src": "^/supporter/?$",
      "dest": "/api/agent/supporter.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/supporter\\.html$",
      "dest": "/api/agent/supporter.js"
    },
    {
      "src": "^/hosted-run/?$",
      "dest": "/api/agent/hosted-run.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/hosted-run\\.html$",
      "dest": "/api/agent/hosted-run.js"
    },
    {
      "src": "^/legal/privacy/?$",
      "dest": "/api/agent/legal-privacy.js"
    },
    {
      "src": "^/privacy/?$",
      "dest": "/api/agent/legal-privacy.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/privacy\\.html$",
      "dest": "/api/agent/legal-privacy.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/legal/privacy\\.html$",
      "dest": "/api/agent/legal-privacy.js"
    },
    {
      "src": "^/legal/terms/?$",
      "dest": "/api/agent/legal-terms.js"
    },
    {
      "src": "^/terms/?$",
      "dest": "/api/agent/legal-terms.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/terms\\.html$",
      "dest": "/api/agent/legal-terms.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/legal/terms\\.html$",
      "dest": "/api/agent/legal-terms.js"
    },
    {
      "src": "^/static/(.*)$",
      "dest": "/api/agent/static.js?path=$1"
    },
    {
      "src": "^/SCBE-AETHERMOORE/static/(.*)$",
      "dest": "/api/agent/static.js?path=$1"
    },
    {
      "src": "^/(?:SCBE-AETHERMOORE/)?product-manual/service-fast-start\\.html$",
      "dest": "/api/agent/service-fast-start.js"
    },
    {
      "src": "^/api/agent/(.*)$",
      "dest": "/api/agent/$1.js"
    },
    {
      "src": "^/api/polly/(.*)$",
      "dest": "/api/polly/$1.js"
    },
    {
      "src": "^/v1/polly/chat/?$",
      "dest": "/api/polly/chat.js"
    },
    {
      "src": "^/v1/polly/feedback/?$",
      "dest": "/api/polly/feedback.js"
    },
    {
      "src": "^/v1/polly/catalog/?$",
      "dest": "/api/polly/catalog.js"
    },
    {
      "src": "^/v1/polly/lead/?$",
      "dest": "/api/polly/lead.js"
    },
    {
      "src": "^/v1/polly/hosted-run/?$",
      "dest": "/api/polly/hosted-run.js"
    },
    {
      "src": "^/v1/polly/stats/?$",
      "dest": "/api/polly/stats.js"
    },
    {
      "src": "^/v1/polly/funnel/?$",
      "dest": "/api/polly/funnel.js"
    },
    {
      "src": "^/v1/billing/stripe-webhook/?$",
      "dest": "/api/billing/stripe_webhook.js"
    }
  ]
}
