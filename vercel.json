{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "case \"$VERCEL_GIT_COMMIT_REF\" in main|launch/*|vercel-test/*|customer/*|fix/launch-*|feat/vercel-*) exit 1 ;; *) exit 0 ;; esac",
  "builds": [
    {
      "src": "api/agent/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/launch$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/api/agent/(.*)$",
      "dest": "/api/agent/$1.js"
    }
  ]
}
