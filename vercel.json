{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "case \"$VERCEL_GIT_COMMIT_REF\" in main|launch/*|vercel-test/*|customer/*|fix/launch-*|feat/vercel-*|fix/vercel-*|feat/polly-*|fix/polly-*) exit 1 ;; *) exit 0 ;; esac",
  "builds": [
    {
      "src": "api/agent/*.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "docs/**"]
      }
    },
    {
      "src": "api/polly/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/launch$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/hire/?$",
      "dest": "/api/agent/hire.js"
    },
    {
      "src": "^/SCBE-AETHERMOORE/hire\\.html$",
      "dest": "/api/agent/hire.js"
    },
    {
      "src": "^/(?:SCBE-AETHERMOORE/)?product-manual/service-fast-start\\.html$",
      "dest": "/api/agent/service-fast-start.js"
    },
    {
      "src": "^/api/agent/(.*)$",
      "dest": "/api/agent/$1.js"
    },
    {
      "src": "^/api/polly/(.*)$",
      "dest": "/api/polly/$1.js"
    },
    {
      "src": "^/v1/polly/chat/?$",
      "dest": "/api/polly/chat.js"
    },
    {
      "src": "^/v1/polly/feedback/?$",
      "dest": "/api/polly/feedback.js"
    },
    {
      "src": "^/v1/polly/catalog/?$",
      "dest": "/api/polly/catalog.js"
    },
    {
      "src": "^/v1/polly/lead/?$",
      "dest": "/api/polly/lead.js"
    },
    {
      "src": "^/v1/polly/stats/?$",
      "dest": "/api/polly/stats.js"
    }
  ]
}
