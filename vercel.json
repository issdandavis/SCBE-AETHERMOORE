{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "git diff --quiet \"$VERCEL_GIT_PREVIOUS_SHA\" \"$VERCEL_GIT_COMMIT_SHA\" -- api/agent vercel.json package.json package-lock.json",
  "builds": [
    {
      "src": "api/agent/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/launch$",
      "dest": "/api/agent/launch.js"
    },
    {
      "src": "^/api/agent/(.*)$",
      "dest": "/api/agent/$1.js"
    }
  ]
}
