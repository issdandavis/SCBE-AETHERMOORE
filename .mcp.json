{
  "mcpServers": {
    "fs": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\issda\\SCBE-AETHERMOORE"
      ],
      "env": {}
    },
    "fetch": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    },
    "scbe-orchestrator": {
      "type": "stdio",
      "command": "python",
      "args": [
        "mcp/orchestrator.py"
      ],
      "env": {
        "SWARM_DRY_RUN": "1"
      }
    },
    "youtube-studio": {
      "type": "stdio",
      "command": "youtube-studio-mcp",
      "args": [],
      "env": {}
    },
    "notion-sweep": {
      "type": "stdio",
      "command": "python",
      "args": [
        "mcp/notion_server.py"
      ],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}",
        "NOTION_TOKEN": "${NOTION_TOKEN}",
        "NOTION_MCP_TOKEN": "${NOTION_MCP_TOKEN}"
      }
    },
    "kaggle": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://www.kaggle.com/mcp",
        "--header",
        "Authorization: Bearer ${KAGGLE_API_TOKEN}"
      ],
      "env": {
        "KAGGLE_API_TOKEN": "${KAGGLE_API_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--slim"
      ],
      "env": {}
    }
  }
}
