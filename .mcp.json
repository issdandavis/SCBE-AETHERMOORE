{
  "mcpServers": {
    "fs": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\issda\\SCBE-AETHERMOORE"
      ],
      "env": {}
    },
    "fetch": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    },
    "scbe-verify": {
      "type": "stdio",
      "command": "python",
      "args": [
        "src/mcp/scbe_verify_mcp.py"
      ],
      "env": {}
    },
    "scbe-govern": {
      "type": "stdio",
      "command": "python",
      "args": [
        "src/mcp/scbe_govern_mcp.py"
      ],
      "env": {}
    },
    "scbe-context": {
      "type": "stdio",
      "command": "python",
      "args": [
        "src/mcp/context_broker_mcp.py"
      ],
      "env": {}
    },
    "kaggle": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://www.kaggle.com/mcp",
        "--header",
        "Authorization: Bearer ${KAGGLE_API_TOKEN}"
      ],
      "env": {
        "KAGGLE_API_TOKEN": "${KAGGLE_API_TOKEN}"
      }
    },
    "stripe": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@stripe/mcp",
        "--tools=all"
      ],
      "env": {
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
      }
    }
  }
}
