{
  "mcpServers": {
    "fs": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\ddavi\\dev\\SCBE-AETHERMOORE"
      ],
      "env": {}
    },
    "fetch": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-fetch"],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    },
    "scbe-governance": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp/scbe_server.py"],
      "env": {
        "SCBE_LEDGER": "artifacts/swarm_ledger.jsonl",
        "GOVERNANCE_MODE": "L13",
        "PYTHONPATH": "."
      }
    },
    "hydra-orchestrator": {
      "type": "stdio",
      "command": "python",
      "args": ["hydra/orchestrator.py", "--mode", "api"],
      "env": {
        "HYDRA_MODE": "production",
        "LEDGER_PATH": "artifacts/swarm_ledger.jsonl",
        "PYTHONPATH": "."
      }
    },
    "swarm-agent-manager": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp/swarm_server.py"],
      "env": {
        "SWARM_MODE": "managed",
        "PYTHONPATH": "."
      }
    },
    "notion-integration": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp/notion_server.py"],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}",
        "PYTHONPATH": "."
      }
    }
  }
}
